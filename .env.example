# ── Database ──────────────────────────────────────────────────
DATABASE_URL=sqlite:///./fire_detection.db
REDIS_URL=redis://localhost:6379/0

# ── Video Paths ───────────────────────────────────────────────
VIDEO_DIR=data/videos
OUTPUT_DIR=data/outputs

# ── Detection Settings ────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.45
FRAME_SKIP=3
MAX_CONCURRENT_STREAMS=10

# ── NASA FIRMS ── get your free key at: ───────────────────────
# https://firms.modaps.eosdis.nasa.gov/api/map_key/
FIRMS_MAP_KEY=your_firms_map_key_here

# ── FIRMS Settings ────────────────────────────────────────────
# Bounding box: west,south,east,north  (default: India subcontinent)
FIRMS_BBOX=68.0,8.0,97.0,37.0
# Satellite source: VIIRS_SNPP_NRT | MODIS_NRT | VIIRS_NOAA20_NRT
FIRMS_SOURCE=MODIS_NRT
# Days of data to fetch (1-10)
FIRMS_DAYS=2

# ── Alert Webhook (optional: Slack / Teams / custom) ──────────
ALERT_WEBHOOK_URL=
